{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.envFile": "${workspaceFolder}/.env",
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/packages/shared-kernel/src",
    "${workspaceFolder}/packages/contracts/src",
    "${workspaceFolder}/packages/observability/src",
    "${workspaceFolder}/packages/security/src",
    "${workspaceFolder}/services/api-gateway/src",
    "${workspaceFolder}/services/application/src",
    "${workspaceFolder}/services/feature/src",
    "${workspaceFolder}/services/scoring/src",
    "${workspaceFolder}/services/decision/src",
    "${workspaceFolder}/services/collab-assistant/src",
    "${workspaceFolder}/services/mlops/src",
    "${workspaceFolder}/services/observability-audit/src"
  ],
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "tests"
  ],
  "python.testing.unittestEnabled": false
}
