# Global defaults for local development only.
# Never commit production credentials. Use a managed secret store in non-local environments.
POSTGRES_DSN=postgresql://credit:credit@localhost:5432/credit_ai_ops
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
ENVIRONMENT=local
LOG_LEVEL=INFO
APP_VERSION=0.1.0
REQUEST_TIMEOUT_SECONDS=3.0
STARTUP_PROBE_TIMEOUT_SECONDS=2.0
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=0.1
RETRY_MAX_DELAY_SECONDS=5.0
RETRY_JITTER_SECONDS=0.2
BROKER_CIRCUIT_FAILURE_THRESHOLD=5
BROKER_CIRCUIT_SUCCESS_THRESHOLD=2
BROKER_BULKHEAD_MAX_CONCURRENCY=10
BROKER_PREFETCH_COUNT=10
OUTBOX_RELAY_BATCH_SIZE=100
OUTBOX_RELAY_POLL_INTERVAL_SECONDS=0.5
OUTBOX_RELAY_CLAIM_LEASE_SECONDS=30
OUTBOX_RELAY_MAX_PUBLISH_ATTEMPTS=5
AUTH_MODE=disabled
AUTH_ISSUER=
AUTH_JWKS_URL=
AUTH_SHARED_SECRET=
AUTH_REQUIRED_SCOPE=
AUTH_REQUIRED_AUDIENCE=
AUTH_CLOCK_SKEW_SECONDS=60
AUTH_SERVICE_TOKEN_URL=
AUTH_SERVICE_CLIENT_ID=
AUTH_SERVICE_CLIENT_SECRET=
AUTH_SERVICE_SCOPE=
AUTH_SERVICE_AUDIENCE=
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=credit-ai-ops
KEYCLOAK_CLIENT_ID=api-gateway
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_INTROSPECTION_URL=
KEYCLOAK_REQUIRED_SCOPE=
KEYCLOAK_REQUIRED_AUDIENCE=
KEYCLOAK_REQUEST_TIMEOUT_SECONDS=2.0
FEATURE_SERVICE_URL=http://localhost:8002
SCORING_SERVICE_URL=http://localhost:8003
DECISION_SERVICE_URL=http://localhost:8004
IDEMPOTENCY_TTL_SECONDS=300
IDEMPOTENCY_STALE_AFTER_SECONDS=120
BROKER_CIRCUIT_RECOVERY_TIMEOUT_SECONDS=15.0
ARTIFACT_ROOT_DIR=build/mlops
MLOPS_MIN_AUC=0.78
MLOPS_MAX_CALIBRATION_ERROR=0.06
ENABLE_LLM=false
ENABLE_PII_LOGGING=false
SKIP_STARTUP_DEPENDENCY_CHECKS=false
